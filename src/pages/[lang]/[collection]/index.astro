---
import { CONTENT, SIDEBAR_NAVIGATION } from "@data/config";
import { getCollection, render } from "astro:content";
import type { CollectionKey } from "astro:content";

import MdxImage from "@/components/docs/markdown/MdxImage.astro";
import MdxLink from "@/components/docs/markdown/MdxLink.astro";
import { languages, defaultLang, type Lang } from "@/i18n";
import DocsLayout from "@/layouts/DocsLayout.astro";
import { buildNavigation } from "@/lib/navigation";

export async function getStaticPaths() {
    const paths: {
        params: { lang: string; collection: string };
        props: {
            collection: CollectionKey;
            nav: Awaited<ReturnType<typeof buildNavigation>>;
            doc: Awaited<ReturnType<typeof getCollection>>[number] | undefined;
            lang: Lang;
        };
    }[] = [];

    const nonDefaultLangs = Object.keys(languages).filter(
        (l) => l !== defaultLang,
    ) as Lang[];

    for (const lang of nonDefaultLangs) {
        for (const sys of CONTENT.systems) {
            const nav = await buildNavigation(SIDEBAR_NAVIGATION, sys.id, lang);
            const allEntries = await getCollection(sys.id as CollectionKey);
            const langEntries = allEntries.filter((e) =>
                e.id.startsWith(`${lang}/`),
            );
            const enEntries = allEntries.filter((e) => e.id.startsWith("en/"));

            // Check for index doc in lang, fallback to en
            let indexDoc =
                langEntries.find((entry) => entry.id === `${lang}/index`) ??
                enEntries.find((entry) => entry.id === "en/index");

            if (!indexDoc) {
                const defaultRedirect = sys.defaultDocRedirect;
                if (defaultRedirect) {
                    const baseRoute = sys.route ?? `/${sys.id}`;
                    const defaultSlug = defaultRedirect
                        .replace(baseRoute + "/", "")
                        .replace(/^\/+/, "");
                    indexDoc =
                        langEntries.find(
                            (entry) => entry.id === `${lang}/${defaultSlug}`,
                        ) ??
                        enEntries.find(
                            (entry) => entry.id === `en/${defaultSlug}`,
                        );
                }
            }

            paths.push({
                params: { lang, collection: sys.id },
                props: {
                    collection: sys.id as CollectionKey,
                    nav,
                    doc: indexDoc,
                    lang,
                },
            });
        }
    }

    return paths;
}

const { nav, doc, lang } = Astro.props as {
    collection: CollectionKey;
    nav: Awaited<ReturnType<typeof buildNavigation>>;
    doc: Awaited<ReturnType<typeof getCollection>>[number] | undefined;
    lang: Lang;
};
const collection = Astro.params.collection as CollectionKey;

if (!doc) {
    return Astro.redirect(`/${lang}`);
}

const { Content, headings } = await render(doc);
const canonicalSlug = doc.id.replace(/^(en|fr)\//, "");

const components = {
    img: MdxImage,
    a: MdxLink,
};
---

<DocsLayout
    frontmatter={{ ...doc, id: canonicalSlug }}
    headings={headings}
    collection={collection}
    nav={nav}
    lang={lang}
>
    <Content components={components} />
</DocsLayout>

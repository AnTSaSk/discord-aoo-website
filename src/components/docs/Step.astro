---
import { cn } from "@/lib/utils";

interface Props {
  number: number;
  title: string;
  class?: string;
}

const { number, title, class: className } = Astro.props;
---

<li class={cn("relative", className)}>
  {/* Numbered circle on the line */}
  <div
    class="absolute -left-12 flex size-8 items-center justify-center rounded-full border-2 border-primary bg-background text-sm font-bold text-primary"
  >
    {number}
  </div>
  <h4 class="mb-2 text-lg font-semibold text-foreground">{title}</h4>
  <div class="text-sm text-muted-foreground [&>p]:my-2 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0">
    <slot />
  </div>
</li>

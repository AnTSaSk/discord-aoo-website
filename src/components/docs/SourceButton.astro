---
import { Icon } from "astro-icon/components";

import { Button } from "@/components/ui/button";
import { getLangFromUrl, useTranslations } from "@/i18n";
import { getSystemRoute } from "@/lib/resolveSystem";

interface Props {
    slug: string;
    collectionId?: string;
}

const { slug, collectionId } = Astro.props;
const base = getSystemRoute(collectionId);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<a href={`${base}/${slug}.md`} target="_blank" rel="noopener noreferrer">
    <Button variant="outline" size="sm" className="gap-2">
        <Icon name="github" class="size-4" />
        {t("sourceButton.label")}
    </Button>
</a>

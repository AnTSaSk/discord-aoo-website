---
import { cn } from "@/lib/utils";

interface Props {
    icon: string;
    title: string;
    description: string;
    href?: string;
    cta?: string;
    class?: string;
}

const { icon, title, description, href, cta, class: className } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
    class={cn(
        "block rounded-lg bg-popover border border-border p-5 space-y-3 transition-colors",
        href && "hover:border-primary/50",
        className,
    )}
    {...href ? { href } : {}}
>
    <div class="text-2xl">{icon}</div>
    <h3 class="text-base font-semibold text-foreground">{title}</h3>
    <p class="text-sm text-muted-foreground">{description}</p>
    {
        href && cta && (
            <span class="inline-flex items-center gap-1 text-sm font-medium text-primary">
                {cta}
                <svg
                    class="size-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                </svg>
            </span>
        )
    }
</Tag>

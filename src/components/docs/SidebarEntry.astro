---
import DocIcon from "./DocIcon.astro";

import { defaultLang, type Lang } from "@/i18n";
import type { SidebarEntryProps } from "@/lib/docs/types";
import { getSystemRoute } from "@/lib/resolveSystem";

const { entry, currentSlug, collectionId, lang = defaultLang } = Astro.props as SidebarEntryProps & {
    collectionId?: string;
    lang?: Lang;
};
const isActive = currentSlug === entry.slug;

const base = getSystemRoute(collectionId);
const localePrefix = lang === defaultLang ? "" : `/${lang}`;
---

<li>
    <a
        href={`${localePrefix}${base}/${entry.slug}`}
        class={`
      flex items-center gap-2 rounded-sm px-2 py-1 text-sm transition-colors
      ${
          isActive
              ? "bg-popover text-popover-foreground font-medium"
              : "text-muted-foreground hover:bg-popover/50 hover:text-foreground"
      }
    `}
        aria-current={isActive ? "page" : undefined}
    >
        {entry.icon && <DocIcon name={entry.icon} class="h-4 w-4" aria-hidden="true" />}
        <span>{entry.label}</span>
    </a>
</li>

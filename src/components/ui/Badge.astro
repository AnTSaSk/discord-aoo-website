---
import { cn } from "@/lib/utils";

type Variant =
    | "default"
    | "secondary"
    | "outline"
    | "destructive"
    | "green"
    | "blue"
    | "purple"
    | "gold"
    | "tier";

interface Props {
    variant?: Variant;
    class?: string;
}

const { variant = "default", class: className } = Astro.props;

const variantClasses: Record<Variant, string> = {
    default: "bg-primary text-primary-foreground",
    secondary: "bg-secondary text-secondary-foreground",
    outline: "border border-border bg-transparent text-foreground",
    destructive: "bg-destructive text-destructive-foreground",
    green: "bg-green/15 text-green border border-green/25",
    blue: "bg-blue/15 text-blue border border-blue/25",
    purple: "bg-purple/15 text-purple border border-purple/25",
    gold: "bg-yellow/15 text-yellow border border-yellow/25",
    tier: "bg-secondary text-muted-foreground border border-border",
};
---

<span
    class={cn(
        "inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium",
        variantClasses[variant],
        className,
    )}
>
    <slot />
</span>

---
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { defaultLang, useTranslatedPath, type Lang } from "@/i18n";

interface Props {
    lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const tp = useTranslatedPath(lang);
---

<a href={tp("/")} class={cn(buttonVariants({ variant: "ghost", size: "icon" }), "flex items-center gap-2")} aria-label="Home">
    <img src="/crystal-icon.svg" alt="AOO" width="20" height="20" class="size-5" />
</a>
